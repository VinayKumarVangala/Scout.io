# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/scout-io?retryWrites=true&w=majority

# Redis Configuration
REDIS_URL=redis://default:<password>@<host>:<port>

# Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ENCRYPTION_KEY=your_32_character_encryption_key_32

# Server Configuration
PORT=5000

# LLM Provider Keys (Optional, can be added per client)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
